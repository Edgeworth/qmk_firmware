{
    "keyboard_name": "memekbd",
    "url": "",
    "bootloader": "caterina",
    "processor": "atmega32u4",
    "build": {
        "lto": true
    },
    "maintainer": "Edgeworth",
    "manufacturer": "Edgeworth",
    "features": {
        "bootmagic": false,
        "console": false, // Console for debug
        "command": false, // Commands for debug and configuration
        "extrakey": true,  // Audio control and System control
        "mousekey": true,  // Mouse keys
        "nkro": true,  // USB Nkey Rollover
        "oled": false,
        "asdfr": false  // test to see if this breaks
    },
    "tapping": {
        "term": 180,
        "permissive_hold": true
    },
    "rgblight": {
        "max_brightness": 40,  // Limit maximum brightness to keep power usage lower.
        "sleep": true,  // Switch off RGB when host sleeps.
        "layers": {
            "enabled": true,  // Change RGB lighting depending on the layer.
            "max": 5
        },
        "default": {
            "hue": 128
        },
        "split_count": [24, 24]  // Number of RGB LEDS (left, right).
    },
    "debounce": 8,
    "usb": {
        "device_version": "0.0.2",
        "vid": "0xFEED",
        "pid": "0x0EDC",
        "polling_interval": 1
    },
    "rgb_matrix": {
        "driver": "ws2812"
    },
    "ws2812": {
        "pin": "D3"  // LED data pin
    },
    "diode_direction": "COL2ROW",
    "matrix_pins": {
        "rows": [ "F4", "F5", "F6", "F7", "B1" ],
        "cols": [ "D4", "C6", "D7", "E6", "B4" ]
    },
    "split": {
        "enabled": true,
        "usb_detect": {
            "enabled": true  // Detect which side is the main side via USB.
        },
        "transport": {
            "method": "i2c",
            "sync": {
                "modifiers": true,  // Send key data to other side - needed for RGB.
                "matrix_state": true  // Send key data to other side - needed for RGB.
            }
        }
    }
}
